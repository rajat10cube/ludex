# Copy to .env for local dev.  All vars are prefixed LUDEX_.

# Storage
LUDEX_DATA_DIR=./data

# Libraries: either point at a YAML config...
# LUDEX_CONFIG=../ludex.yaml
# ...or use a single-root fallback:
# LUDEX_GAMES_DIR=D:/games

# Scanning
LUDEX_SCAN_ON_START=true
LUDEX_COMPUTE_SIZES=true

# Artwork / metadata (optional, like a TVDB key in Jellyfin).
# SteamGridDB -> cover art; IGDB (Twitch) -> description/genres/year/rating.
# LUDEX_STEAMGRIDDB_KEY=your-steamgriddb-key
# LUDEX_IGDB_CLIENT_ID=your-twitch-client-id
# LUDEX_IGDB_CLIENT_SECRET=your-twitch-client-secret

# Auth
LUDEX_AUTH=basic
LUDEX_AUTH_USER=admin
LUDEX_AUTH_PASS=change-me

# Dev
LUDEX_DEV_CORS=true
